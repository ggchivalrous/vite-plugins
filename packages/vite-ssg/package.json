{
  "name": "@ggcv/vite-plugin-ssg",
  "version": "1.0.0",
  "description": "Vite plugin for Static Site Generation (SSG) — prerender Vue/React apps to static HTML at build time",
  "keywords": [
    "prerender",
    "ssg",
    "ssr",
    "static-site-generation",
    "vite",
    "vite-plugin",
    "vue"
  ],
  "homepage": "https://github.com/ggchivalrous/vite-plugins/tree/master/packages/vite-ssg#readme",
  "bugs": {
    "url": "https://github.com/ggchivalrous/vite-plugins/issues"
  },
  "license": "MIT",
  "author": "ggchivalrous",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ggchivalrous/vite-plugins.git",
    "directory": "packages/vite-ssg"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "typecheck": "tsc --noEmit",
    "release": "bumpp",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "bumpp": "catalog:",
    "happy-dom": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "vue": "catalog:"
  },
  "peerDependencies": {
    "happy-dom": "catalog:",
    "vite": "catalog:"
  },
  "peerDependenciesMeta": {
    "happy-dom": {
      "optional": true
    }
  }
}
